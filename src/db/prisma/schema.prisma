generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model TestRun {
  id             String        @id @default(cuid())
  runName        String?
  modelUnderTest String
  config         Json
  status         String        @default("running") // running | completed | failed
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  summary        Json?
  scenarioRuns   ScenarioRun[]
  llmCalls       LlmCall[]
  createdAt      DateTime      @default(now())
}

model ScenarioRun {
  id             String         @id @default(cuid())
  testRunId      String
  testRun        TestRun        @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  scenarioId     String
  scenarioName   String
  scenarioConfig Json
  status         String         @default("running") // running | passed | failed
  totalRounds    Int            @default(0)
  aggregate      Float?
  startedAt      DateTime       @default(now())
  completedAt    DateTime?
  conversations  Conversation[]
  createdAt      DateTime       @default(now())

  @@index([testRunId])
}

model Conversation {
  id              String           @id @default(cuid())
  scenarioRunId   String
  scenarioRun     ScenarioRun      @relation(fields: [scenarioRunId], references: [id], onDelete: Cascade)
  roundNumber     Int
  turnType        String           // seed | follow_up
  seedQuestionId  String?
  question        String
  response        String
  latencyMs       Int?
  askedAt         DateTime
  respondedAt     DateTime
  judgeVerdict    JudgeVerdict?
  analysisResults AnalysisResult[]
  createdAt       DateTime         @default(now())

  @@index([scenarioRunId])
  @@index([scenarioRunId, roundNumber])
}

model JudgeVerdict {
  id               String       @id @default(cuid())
  conversationId   String       @unique
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  accuracyScore    Float
  relevanceScore   Float
  totalScore       Float
  reasoning        String
  rawResponse      String?
  judgeModel       String?
  createdAt        DateTime     @default(now())
}

model AnalysisResult {
  id               String       @id @default(cuid())
  conversationId   String
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  strategy         String       // exact | semantic
  score            Float
  groundTruth      String?
  judgeScore       Float?
  difference       Float?
  isHumanNeed      Boolean      @default(false)
  createdAt        DateTime     @default(now())

  @@index([conversationId])
  @@index([strategy])
}

model LlmCall {
  id             String   @id @default(cuid())
  testRunId      String
  testRun        TestRun  @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  caller         String   // judge | questionnaire | semantic_analyzer
  provider       String   // gemini
  model          String
  inputMessages  Json
  outputContent  String
  inputTokens    Int?
  outputTokens   Int?
  latencyMs      Int?
  createdAt      DateTime @default(now())

  @@index([testRunId])
  @@index([caller])
}
